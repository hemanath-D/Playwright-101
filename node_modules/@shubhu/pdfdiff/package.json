{
  "name": "@shubhu/pdfdiff",
  "version": "1.6.0",
  "description": "Platform/framework agnostic PDF diffing library with CLI support",
  "main": "src/index.js",
  "browser": "src/browser.js",
  "type": "module",
  "bin": {
    "pdfdiff": "bin/cli.js"
  },
  "files": [
    "src/",
    "bin/",
    "dist/"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "typecheck": "npx -p typescript tsc --project jsconfig.json",
    "build": "rollup -c && rollup -c rollup.standalone.config.js",
    "prebuild": "mkdir -p dist"
  },
  "keywords": [
    "pdf",
    "diff",
    "cli",
    "comparison",
    "text-extraction"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "diff": "^8.0.2",
    "pdfjs-dist": "4.10.38"
  },
  "optionalDependencies": {
    "chalk": "^5.6.0"
  },
  "devDependencies": {
    "@anaralabs/lector": "^3.5.14",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@types/node": "^24.3.0",
    "rollup": "^4.46.4"
  }
}
